                        <li class="list-group-item d-flex justify-content-between align-items-center"><a href="/cadir/etkinlik-fuar-cadiri">Etkinlik Fuar Çadırı</a><span class="badge badge-pill bg-default">14</span> </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center"><a href="/tente/pergola-tente">Pergola Tente</a><span class="badge badge-pill bg-default">14</span> </li>
