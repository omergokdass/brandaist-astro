                width: 55px; /* Initial circle width */
                height: 55px;
                overflow: hidden;
                white-space: nowrap;
            }

            .float-btn i {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 55px; /* Icon container exactly matches collapsed button */
                height: 55px;
                margin: 0;
                flex-shrink: 0; /* Prevent squishing */
            }

            .float-btn span {
                display: inline-block;
                max-width: 0;
                opacity: 0;
                transition:
                    opacity 0.3s ease,
                    transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
                transform: translateX(-10px); /* Subtle slide-in effect */
            }

            .float-btn:hover {
                box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
                color: #fff !important;
                width: 160px; /* Expanded width */
                padding-left: 20px; /* Breathing room for text when expanding right */
            }

            .float-btn:hover span {
                max-width: 100px;
