---
export interface GalleryImage {
    src: string;
    alt: string;
}

export interface Props {
    images: GalleryImage[];
}

const { images } = Astro.props;
---

<div class="modern-gallery-container gap-3">
    {
        images.map((img) => (
            <a
                href={img.src}
                class="glightbox modern-gallery-item"
                data-gallery="gallery1"
            >
                <img
                    src={img.src}
                    alt={img.alt}
                    class="img-fluid rounded shadow-sm"
                    width="400"
                    height="300"
                    loading="lazy"
                    decoding="async"
                />
                <div class="gallery-overlay">
                    <i class="fa fa-search-plus text-white fa-2x" />
                </div>
            </a>
        ))
    }
</div>

<style>
    /* CSS Multi-column layout for Masonry-like grid */
    .modern-gallery-container {
        columns: 1;
        column-gap: 1.5rem;
    }

    @media (min-width: 576px) {
        .modern-gallery-container {
            columns: 2;
        }
    }

    @media (min-width: 992px) {
        .modern-gallery-container {
            columns: 3;
        }
    }

    .modern-gallery-item {
        display: block;
        position: relative;
        margin-bottom: 1.5rem;
        border-radius: 0.5rem;
        overflow: hidden;
        -webkit-column-break-inside: avoid;
        page-break-inside: avoid;
        break-inside: avoid;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    .modern-gallery-item img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.4s ease;
    }

    .gallery-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none; /* Let clicks pass through to the <a> tag */
    }

    .modern-gallery-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15) !important;
    }

    .modern-gallery-item:hover img {
        transform: scale(1.05);
    }

    .modern-gallery-item:hover .gallery-overlay {
        opacity: 1;
    }
</style>

<script>
    // Initialize GLightbox
    // We import it here so it's only bundled and executed on pages that use this component
    import GLightbox from "glightbox";
    import "glightbox/dist/css/glightbox.min.css";

    document.addEventListener("DOMContentLoaded", () => {
        GLightbox({
            selector: ".glightbox",
            touchNavigation: true,
            loop: true,
            zoomable: true,
        });
    });
</script>
