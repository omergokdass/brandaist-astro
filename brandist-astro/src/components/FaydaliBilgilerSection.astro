---

---

<section
    class="bg-gray-50 py-16 lg:py-24"
    aria-labelledby="faydali-bilgiler-baslik"
>
    <div class="container mx-auto px-4 lg:px-8">
        <div class="text-center mb-16">
            <h2
                id="faydali-bilgiler-baslik"
                class="text-3xl md:text-4xl font-bold text-gray-900 inline-block relative pb-3"
            >
                Faydalı Bilgiler & Blog
                <span
                    class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-20 h-1 bg-primary rounded-full"
                ></span>
            </h2>
        </div>

        <div class="max-w-4xl mx-auto">
            <!-- BlogPost 1 -->
            <article
                class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-8 overflow-hidden hover:shadow-lg transition-all duration-300 group"
            >
                <div class="flex flex-col md:flex-row items-center">
                    <div class="w-full md:w-5/12 overflow-hidden">
                        <a href="/blog/depo-cadiri-nedir" class="block">
                            <figure
                                class="relative overflow-hidden aspect-[16/10] md:aspect-auto md:h-full"
                            >
                                <img
                                    src="/style/brand/img/depo-cadiri-fiyatlari.webp"
                                    width="400"
                                    height="220"
                                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
                                    alt="Depo Çadırı Fiyatları"
                                    loading="lazy"
                                    decoding="async"
                                />
                                <div
                                    class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-300"
                                >
                                </div>
                            </figure>
                        </a>
                    </div>
                    <div class="w-full md:w-7/12">
                        <div class="p-6 lg:p-8 text-left">
                            <h3
                                class="text-xl md:text-2xl font-bold text-gray-900 mb-3"
                            >
                                <a
                                    href="/blog/depo-cadiri-nedir"
                                    class="hover:text-primary transition-colors"
                                >
                                    Depo Çadırı Fiyatları ve Kullanım
                                    Avantajları Nelerdir?
                                </a>
                            </h3>
                            <p class="text-gray-600 mb-6 leading-relaxed">
                                Depo çadırı çözümlerine dair tüm detaylar: Fiyat
                                faktörleri, avantajlar, dayanıklılık oranları ve
                                kurulum bilgileri.
                            </p>
                            <a
                                href="/blog/depo-cadiri-nedir"
                                class="inline-flex items-center text-sm font-bold text-white bg-primary px-5 py-2.5 rounded-lg hover:bg-blue-600 transition-colors shadow-sm"
                            >
                                <i class="fa fa-book-open mr-2"></i> Devamını Oku
                            </a>
                        </div>
                    </div>
                </div>
            </article>

            <!-- BlogPost 2 -->
            <article
                class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-8 overflow-hidden hover:shadow-lg transition-all duration-300 group"
            >
                <div class="flex flex-col md:flex-row items-center">
                    <div class="w-full md:w-5/12 overflow-hidden">
                        <a
                            href="/blog/kis-bahcesi-icin-seffaf-branda-secimi"
                            class="block"
                        >
                            <figure
                                class="relative overflow-hidden aspect-[16/10] md:aspect-auto md:h-full"
                            >
                                <img
                                    src="/style/brand/img/seffaf-branda2.webp"
                                    width="400"
                                    height="220"
                                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
                                    alt="Kış Bahçesi İçin Şeffaf Branda Seçimi"
                                    loading="lazy"
                                    decoding="async"
                                />
                                <div
                                    class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-300"
                                >
                                </div>
                            </figure>
                        </a>
                    </div>
                    <div class="w-full md:w-7/12">
                        <div class="p-6 lg:p-8 text-left">
                            <h3
                                class="text-xl md:text-2xl font-bold text-gray-900 mb-3"
                            >
                                <a
                                    href="/blog/kis-bahcesi-icin-seffaf-branda-secimi"
                                    class="hover:text-primary transition-colors"
                                >
                                    Kış Bahçesi İçin Şeffaf Branda Seçimi:
                                    Nelere Dikkat Edilmeli?
                                </a>
                            </h3>
                            <p class="text-gray-600 mb-6 leading-relaxed">
                                Kış bahçesi yaptırmak isteyenlerin en çok
                                sorduğu sorulardan biri doğru branda
                                malzemesinin nasıl seçileceğidir. Şeffaf
                                fermuarlı sistemlerden mika kullanımına kadar
                                tüm detayları rehberimizde.
                            </p>
                            <a
                                href="/blog/kis-bahcesi-icin-seffaf-branda-secimi"
                                class="inline-flex items-center text-sm font-bold text-white bg-primary px-5 py-2.5 rounded-lg hover:bg-blue-600 transition-colors shadow-sm"
                            >
                                <i class="fa fa-book-open mr-2"></i> Devamını Oku
                            </a>
                        </div>
                    </div>
                </div>
            </article>

            <!-- BlogPost 3 -->
            <article
                class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-4 overflow-hidden hover:shadow-lg transition-all duration-300 group"
            >
                <div class="flex flex-col md:flex-row items-center">
                    <div class="w-full md:w-5/12 overflow-hidden">
                        <a
                            href="/blog/depo-cadiri-alirken-dikkat-edilmesi-gerekenler"
                            class="block"
                        >
                            <figure
                                class="relative overflow-hidden aspect-[16/10] md:aspect-auto md:h-full"
                            >
                                <img
                                    src="/style/brand/img/depo-cadiri.webp"
                                    width="400"
                                    height="220"
                                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
                                    alt="Endüstriyel Depo Çadırı"
                                    loading="lazy"
                                    decoding="async"
                                />
                                <div
                                    class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-300"
                                >
                                </div>
                            </figure>
                        </a>
                    </div>
                    <div class="w-full md:w-7/12">
                        <div class="p-6 lg:p-8 text-left">
                            <h3
                                class="text-xl md:text-2xl font-bold text-gray-900 mb-3"
                            >
                                <a
                                    href="/blog/depo-cadiri-alirken-dikkat-edilmesi-gerekenler"
                                    class="hover:text-primary transition-colors"
                                >
                                    Endüstriyel Depo Çadırı Alırken Dikkat
                                    Edilmesi Gereken Yönler
                                </a>
                            </h3>
                            <p class="text-gray-600 mb-6 leading-relaxed">
                                Fabrika alanı veya depolama hacmini artırmak
                                için ekonomik olan endüstriyel depo çadırı
                                alırken nelere dikkat etmeniz gerektiğini
                                biliyor musunuz?
                            </p>
                            <a
                                href="/blog/depo-cadiri-alirken-dikkat-edilmesi-gerekenler"
                                class="inline-flex items-center text-sm font-bold text-white bg-primary px-5 py-2.5 rounded-lg hover:bg-blue-600 transition-colors shadow-sm"
                            >
                                <i class="fa fa-book-open mr-2"></i> Devamını Oku
                            </a>
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="mt-12 text-center">
            <a
                href="/blog"
                class="inline-block bg-gray-900 text-white font-bold text-lg px-8 py-3 rounded-full shadow-md hover:bg-gray-800 hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
            >
                Tüm Yazıları İncele
            </a>
        </div>
    </div>
</section>
