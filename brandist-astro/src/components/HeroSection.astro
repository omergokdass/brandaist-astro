---

---

<div
    class="relative w-full h-[100vh] overflow-hidden bg-black hero-slider-wrapper"
>
    <div class="swiper hero-swiper h-full w-full">
        <div class="swiper-wrapper">
            <!-- Slide 1 -->
            <div class="swiper-slide relative bg-black">
                <img
                    src="/style/brand/img/amir-branda-tente-montaj-istanbul.webp"
                    alt="Amir Branda uzman montaj ekibi tente kurulumunda"
                    class="w-full h-full object-cover"
                    width="1920"
                    height="1080"
                    fetchpriority="high"
                    loading="eager"
                />
                <div
                    class="absolute inset-0 bg-black/40 z-10 transition-colors duration-300"
                >
                </div>
                <div
                    class="absolute inset-0 flex flex-col items-center justify-center text-center z-20 px-4 pointer-events-none"
                >
                    <h2
                        class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-4 drop-shadow-[0_4px_8px_rgba(0,0,0,0.8)] tracking-tight"
                    >
                        Amir Branda ile
                    </h2>
                    <p
                        class="text-2xl md:text-3xl lg:text-4xl text-white font-light drop-shadow-[0_3px_6px_rgba(0,0,0,0.8)]"
                    >
                        açık havanın tadını çıkarın
                    </p>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="swiper-slide relative bg-black">
                <img
                    src="/style/brand/img/seffaf-kis-bahcesi-brandasi.webp"
                    alt="Kafe ve kış bahçesi için şeffaf branda kaplaması"
                    class="w-full h-full object-cover"
                    width="1920"
                    height="1080"
                    loading="lazy"
                />
                <div
                    class="absolute inset-0 bg-black/40 z-10 transition-colors duration-300"
                >
                </div>
                <div
                    class="absolute inset-0 flex flex-col items-center justify-center text-center z-20 px-4 pointer-events-none"
                >
                    <h2
                        class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-4 drop-shadow-[0_4px_8px_rgba(0,0,0,0.8)] tracking-tight"
                    >
                        Amir Branda ile
                    </h2>
                    <p
                        class="text-2xl md:text-3xl lg:text-4xl text-white font-light drop-shadow-[0_3px_6px_rgba(0,0,0,0.8)]"
                    >
                        yağmurlu günlerden korunun
                    </p>
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="swiper-slide relative bg-black">
                <img
                    src="/style/brand/img/branda-tente-cadir-sistemleri-imalati.webp"
                    alt="Amir Branda kaliteli branda, tente ve çadır sistemleri imalatı"
                    class="w-full h-full object-cover"
                    width="1920"
                    height="1080"
                    loading="lazy"
                />
                <div
                    class="absolute inset-0 bg-black/40 z-10 transition-colors duration-300"
                >
                </div>
                <div
                    class="absolute inset-0 flex flex-col items-center justify-center text-center z-20 px-4 pointer-events-none"
                >
                    <h2
                        class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-4 drop-shadow-[0_4px_8px_rgba(0,0,0,0.8)] tracking-tight"
                    >
                        Amir Branda ile
                    </h2>
                    <p
                        class="text-2xl md:text-3xl lg:text-4xl text-white font-light drop-shadow-[0_3px_6px_rgba(0,0,0,0.8)]"
                    >
                        güneşli günlerin tadını çıkarın
                    </p>
                </div>
            </div>
        </div>

        <!-- Add Pagination -->
        <div class="swiper-pagination hero-swiper-pagination pb-8 lg:pb-12">
        </div>
        <!-- Add Navigation -->
        <div
            class="swiper-button-prev hero-swiper-button-prev text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] lg:ml-8 transition-transform hover:scale-110"
        >
        </div>
        <div
            class="swiper-button-next hero-swiper-button-next text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] lg:mr-8 transition-transform hover:scale-110"
        >
        </div>

        <style>
            /* Make sure pagination bullets are visible over dark background */
            :global(.hero-swiper-pagination .swiper-pagination-bullet) {
                background: #ffffff;
                opacity: 0.5;
                width: 12px;
                height: 12px;
                transition: all 0.3s ease;
            }
            :global(.hero-swiper-pagination .swiper-pagination-bullet-active) {
                opacity: 1;
                background: #ffffff;
                transform: scale(1.3);
            }
            :global(.hero-swiper-button-next::after),
            :global(.hero-swiper-button-prev::after) {
                font-size: 2.5rem !important;
                font-weight: bold;
            }
        </style>

        <script is:inline>
            document.addEventListener("astro:page-load", function () {
                // Ensure Swiper is loaded before initializing
                const initSwiper = () => {
                    if (typeof Swiper !== "undefined") {
                        new Swiper(".hero-swiper", {
                            loop: true,
                            effect: "fade",
                            fadeEffect: { crossFade: true },
                            speed: 1000,
                            autoplay: {
                                delay: 6000,
                                disableOnInteraction: false,
                            },
                            pagination: {
                                el: ".hero-swiper-pagination",
                                clickable: true,
                            },
                            navigation: {
                                nextEl: ".hero-swiper-button-next",
                                prevEl: ".hero-swiper-button-prev",
                            },
                            grabCursor: true,
                        });
                    } else {
                        // Retry if Swiper hasn't loaded yet
                        setTimeout(initSwiper, 100);
                    }
                };
                initSwiper();
            });
        </script>
    </div>
</div>
