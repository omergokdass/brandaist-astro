---

---

<div
    class="hero-slider-wrapper position-relative w-100 overflow-hidden"
    style="height: 100vh;"
>
    <div class="swiper hero-swiper h-100">
        <div class="swiper-wrapper">
            <!-- Slide 1 -->
            <div class="swiper-slide bg-dark position-relative">
                <img
                    src="/style/brand/img/amir-branda-tente-montaj-istanbul.webp"
                    alt="Amir Branda uzman montaj ekibi tente kurulumunda"
                    class="w-100 h-100"
                    fetchpriority="high"
                    loading="eager"
                    style="object-fit: cover;"
                />
                <div
                    class="background-overlay position-absolute w-100 h-100"
                    style="top: 0; left: 0; background: rgba(0,0,0,0.1); z-index: 1;"
                >
                </div>
                <div
                    class="position-absolute text-center w-100"
                    style="top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 3;"
                >
                    <h2
                        class="display-3 font-weight-bold text-white mb-3 text-shadow"
                    >
                        Amir Branda ile
                    </h2>
                    <p class="h2 text-white text-shadow font-weight-light mb-4">
                        açık havanın tadını çıkarın
                    </p>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="swiper-slide bg-dark position-relative">
                <img
                    src="/style/brand/img/seffaf-kis-bahcesi-brandasi.webp"
                    alt="Kafe ve kış bahçesi için şeffaf branda kaplaması"
                    class="w-100 h-100"
                    loading="lazy"
                    style="object-fit: cover;"
                />
                <div
                    class="background-overlay position-absolute w-100 h-100"
                    style="top: 0; left: 0; background: rgba(0,0,0,0.1); z-index: 1;"
                >
                </div>
                <div
                    class="position-absolute text-center w-100"
                    style="top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 3;"
                >
                    <h2
                        class="display-3 font-weight-bold text-white mb-3 text-shadow"
                    >
                        Amir Branda ile
                    </h2>
                    <p class="h2 text-white text-shadow font-weight-light mb-4">
                        yağmurlu günlerden korunun
                    </p>
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="swiper-slide bg-dark position-relative">
                <img
                    src="/style/brand/img/branda-tente-cadir-sistemleri-imalati.webp"
                    alt="Amir Branda kaliteli branda, tente ve çadır sistemleri imalatı"
                    class="w-100 h-100"
                    loading="lazy"
                    style="object-fit: cover;"
                />
                <div
                    class="background-overlay position-absolute w-100 h-100"
                    style="top: 0; left: 0; background: rgba(0,0,0,0.1); z-index: 1;"
                >
                </div>
                <div
                    class="position-absolute text-center w-100"
                    style="top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 3;"
                >
                    <h2
                        class="display-3 font-weight-bold text-white mb-3 text-shadow"
                    >
                        Amir Branda ile
                    </h2>
                    <p class="h2 text-white text-shadow font-weight-light mb-4">
                        güneşli günlerin tadını çıkarın
                    </p>
                </div>
            </div>
        </div>

        <!-- Add Pagination -->
        <div class="swiper-pagination hero-swiper-pagination"></div>
        <!-- Add Navigation -->
        <div
            class="swiper-button-prev hero-swiper-button-prev"
            style="color: white; text-shadow: 0px 0px 5px rgba(0,0,0,0.5);"
        >
        </div>
        <div
            class="swiper-button-next hero-swiper-button-next"
            style="color: white; text-shadow: 0px 0px 5px rgba(0,0,0,0.5);"
        >
        </div>

        <style>
            .hero-slider-wrapper {
                /* Fullscreen setup handled via inline style and Bootstrap utility */
            }
            .text-shadow {
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.6);
            }

            /* Make sure pagination bullets are visible over dark background */
            :global(.hero-swiper-pagination .swiper-pagination-bullet) {
                background: #fff;
                opacity: 0.5;
                width: 12px;
                height: 12px;
            }
            :global(.hero-swiper-pagination .swiper-pagination-bullet-active) {
                opacity: 1;
                background: #fff;
        </style>

        <script is:inline>
            window.addEventListener("load", function () {
                if (typeof Swiper !== "undefined") {
                    new Swiper(".hero-swiper", {
                        loop: true,
                        effect: "fade",
                        fadeEffect: { crossFade: true },
                        speed: 800,
                        autoplay: {
                            delay: 5000,
                            disableOnInteraction: false,
                        },
                        pagination: {
                            el: ".hero-swiper-pagination",
                            clickable: true,
                        },
                        navigation: {
                            nextEl: ".hero-swiper-button-next",
                            prevEl: ".hero-swiper-button-prev",
                        },
                    });
                }
            });
        </script>
    </div>
</div>
