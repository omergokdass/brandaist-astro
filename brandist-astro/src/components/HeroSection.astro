---

---

<section
    class="relative w-full h-auto min-h-[90vh] bg-gray-900 flex items-center pt-24 pb-12 overflow-hidden"
>
    <!-- Decorative background elements -->
    <div
        class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0"
    >
        <div
            class="absolute -top-[10%] -left-[5%] w-[50%] h-[50%] rounded-full bg-primary/10 blur-3xl"
        >
        </div>
        <div
            class="absolute -bottom-[10%] -right-[5%] w-[40%] h-[40%] rounded-full bg-blue-500/10 blur-3xl"
        >
        </div>
    </div>

    <div class="container mx-auto px-4 lg:px-8 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
            <!-- Left Side: Image Grid/Display -->
            <div
                class="w-full lg:w-1/2 relative flex items-center justify-center order-1 lg:order-1"
            >
                <!-- Main Image wrapper -->
                <div
                    class="relative w-full max-w-[280px] sm:max-w-sm lg:max-w-[380px] xl:max-w-[420px] mx-auto rounded-3xl p-2 bg-gradient-to-tr from-white/10 to-white/5 border border-white/10 backdrop-blur-sm shadow-2xl"
                >
                    <img
                        src="/style/brand/img/istanbul-brandaci-tenteci-cadirci.webp"
                        alt="Amir Branda uzman branda, tente ve çadır sistemleri"
                        class="relative z-10 w-full h-auto object-cover rounded-2xl shadow-inner border border-gray-800/20"
                        width="800"
                        height="600"
                        fetchpriority="high"
                        loading="eager"
                    />

                    <!-- Floating Badge -->
                    <div
                        class="absolute z-20 -bottom-6 -right-6 lg:-right-8 bg-gray-800 p-4 lg:p-6 rounded-2xl shadow-xl border border-white/10 flex items-center gap-4 animate-bounce-slow backdrop-blur-md"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-yellow-500/20 text-yellow-400 flex items-center justify-center text-2xl"
                        >
                            <i class="fa fa-star"></i>
                        </div>
                        <div>
                            <div class="font-bold text-white text-lg">
                                15+ Yıllık
                            </div>
                            <div class="text-gray-400 text-sm font-medium">
                                Sektör Tecrübesi
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Text & Actions -->
            <div
                class="w-full lg:w-1/2 flex flex-col justify-center text-center lg:text-left mt-10 lg:mt-0 order-2 lg:order-2"
            >
                <span
                    class="inline-block py-1.5 px-4 rounded-full bg-white/10 text-primary font-bold text-sm tracking-wide uppercase mb-6 w-max mx-auto lg:mx-0 border border-white/10 backdrop-blur-sm"
                >
                    Branda Çadır & Tente İmalatçısı
                </span>

                <h1
                    class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold text-white mb-6 tracking-tight leading-[1.2]"
                >
                    Amir Branda ile<br />
                    <span class="text-primary relative inline-block">
                        Dört Mevsim Konfor
                        <svg
                            class="absolute w-full h-3 -bottom-1 left-0 text-blue-500/60"
                            viewBox="0 0 100 10"
                            preserveAspectRatio="none"
                            ><path
                                d="M0 5 Q 50 10 100 5"
                                stroke="currentColor"
                                stroke-width="8"
                                fill="transparent"></path></svg
                        >
                    </span>
                </h1>

                <p
                    class="text-lg md:text-xl text-gray-300 font-light mb-10 max-w-2xl mx-auto lg:mx-0 leading-relaxed"
                >
                    Yağmurlu günlerden korunun, güneşli günlerin tadını çıkarın.
                    Uzman gölgelendirme ve yalıtımlı çadır sistemleriyle
                    mekanınıza değer katıyoruz.
                </p>

                <div
                    class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center w-full"
                >
                    <a
                        href="tel:+905386044851"
                        class="w-full sm:w-auto px-8 py-4 bg-primary hover:bg-blue-600 text-white font-bold rounded-xl text-lg shadow-[0_4px_15px_rgba(76,166,229,0.3)] hover:shadow-[0_8px_25px_rgba(76,166,229,0.5)] transition-all duration-300 transform hover:-translate-y-1 text-center flex items-center justify-center"
                    >
                        <i class="fa fa-phone mr-2"></i> Hemen Teklif Alın
                    </a>
                    <a
                        href="/urunler"
                        class="w-full sm:w-auto px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 hover:border-white/30 text-white font-bold rounded-xl text-lg shadow-sm hover:shadow-md transition-all duration-300 transform hover:-translate-y-1 text-center flex items-center justify-center backdrop-blur-sm"
                    >
                        Ürünlerimizi İnceleyin <i
                            class="fa fa-arrow-right ml-2 text-primary"></i>
                    </a>
                </div>

                <!-- Trust Indicators -->
                <div
                    class="mt-12 flex items-center justify-center lg:justify-start gap-8 border-t border-white/10 pt-8 opacity-90"
                >
                    <div class="flex items-center gap-3">
                        <div
                            class="w-12 h-12 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center text-xl"
                        >
                            <i class="fa fa-shield-alt"></i>
                        </div>
                        <div class="text-left">
                            <h4 class="font-bold text-white text-sm">
                                Garantili
                            </h4>
                            <p class="text-xs text-gray-400">Üretim & Montaj</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div
                            class="w-12 h-12 rounded-full bg-blue-500/20 text-primary flex items-center justify-center text-xl"
                        >
                            <i class="fa fa-truck-fast"></i>
                        </div>
                        <div class="text-left">
                            <h4 class="font-bold text-white text-sm">
                                Ücretsiz Keşif
                            </h4>
                            <p class="text-xs text-gray-400">
                                İstanbul İçi Hizmet
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
