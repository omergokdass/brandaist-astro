const currentData = data[category];
---

<aside class="w-full px-4 hidden lg:block">
    <!-- About Widget -->
    <div class="mb-10">
        <h3
            class="text-xl font-bold text-gray-800 mb-5 pb-2 border-b-2 border-primary relative uppercase tracking-wide"
        >
            Hakkımızda
        </h3>
        <figure class="mb-5">
            <img
                src="/style/brand/img/branda-logo.webp"
                alt="Amir Branda Tente ve Çadır Sistemleri"
                class="w-full max-w-[300px] h-auto object-contain mx-auto"
                style="aspect-ratio: 2/1;"
                loading="lazy"
            />
        </figure>
        <p class="text-gray-600 mb-5 leading-relaxed text-[15px]">
            {currentData.desc}
        </p>

        <!-- Social Icons -->
        <div class="flex space-x-3">
            <a
                href="https://www.facebook.com/amirbrandacadirtente/"
                target="_blank"
                class="flex items-center justify-center w-10 h-10 rounded-full bg-blue-600 text-white hover:-translate-y-1 transition-transform duration-300"
            >
                <i class="fa-brands fa-facebook-f text-lg"></i>
            </a>
            <a
                href="https://tr.pinterest.com/amirbranda/"
                target="_blank"
                class="flex items-center justify-center w-10 h-10 rounded-full bg-red-600 text-white hover:-translate-y-1 transition-transform duration-300"
            >
                <i class="fa-brands fa-pinterest text-lg"></i>
            </a>
            <a
                href="https://www.instagram.com/branda.ist/"
                target="_blank"
                class="flex items-center justify-center w-10 h-10 rounded-full bg-pink-600 text-white hover:-translate-y-1 transition-transform duration-300"
            >
                <i class="fa-brands fa-instagram text-lg"></i>
            </a>
            <a
                href="https://x.com/amirbrandaist"
                target="_blank"
                class="flex items-center justify-center w-10 h-10 rounded-full bg-black text-white hover:-translate-y-1 transition-transform duration-300"
            >
                <i class="fa-brands fa-x-twitter text-lg"></i>
            </a>
        </div>
    </div>

    <!-- Category Links Modern Widget -->
    <div
        class="bg-white rounded-xl shadow-[0_4px_15px_rgba(0,0,0,0.05)] border border-black/5 hover:shadow-[0_6px_20px_rgba(0,0,0,0.08)] transition-all duration-300 p-6 mb-8 relative overflow-hidden"
    >
        <h3
            class="text-xl font-bold text-gray-800 mb-5 pb-3 border-b border-gray-200 relative uppercase tracking-wide"
        >
            {currentData.title}
            <span class="absolute bottom-[-1px] left-0 w-16 h-[2px] bg-primary"
            ></span>
        </h3>
        <ul class="flex flex-col rounded-lg">
            {
                currentData.links.map((link) => (
                    <li class="group flex items-center justify-between border-b border-gray-100 last:border-b-0">
                        <a
                            href={link.url}
                            class="py-3 px-2 flex-1 text-gray-600 font-medium text-[15px] group-hover:text-primary transition-all duration-300 flex items-center group-hover:translate-x-1"
                        >
                            <span class="opacity-0 group-hover:opacity-100 mr-2 -translate-x-2 group-hover:translate-x-0 transition-all duration-300 text-primary font-bold">
                                •
                            </span>
                            {link.text}
                        </a>
                        <span class="text-gray-400 group-hover:text-primary transition-colors duration-300 text-sm group-hover:translate-x-0.5 transform">
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 5l7 7-7 7"
                                />
                            </svg>
                        </span>
                    </li>
                ))
            }
        </ul>
    </div>
</aside>
