---

<aside class="col-md-4 sidebar">
    <div class="sidebox widget">
        <h3 class="widget-title">Hakkımızda</h3>
        <figure class="mb-20">
            <img
                src="/style/brand/img/branda-logo.webp"
                alt="Amir Branda Tente ve Çadır Sistemleri"
                loading="lazy"
            />
        </figure>
        <p>{currentData.desc}</p>
        <ul class="social social-color social-s">
            <li>
                <a
                    href="https://www.facebook.com/amirbrandacadirtente/"
                    target="_blank"><i class="fa-brands fa-facebook-f"></i></a
                >
            </li>
            <li>
                <a href="https://tr.pinterest.com/amirbranda/" target="_blank"
                    ><i class="fa-brands fa-pinterest"></i></a
                >
            </li>
            <li>
                <a href="https://www.instagram.com/branda.ist/" target="_blank"
                    ><i class="fa-brands fa-instagram"></i></a
                >
            </li>
            <li>
                <a href="https://x.com/amirbrandaist" target="_blank"
                    ><i class="fa-brands fa-twitter"></i></a
                >
            </li>
        </ul>
        <div class="clearfix"></div>
    </div>
    <!-- /.widget -->
    <div class="sidebox widget modern-sidebar-widget">
        <h3 class="widget-title modern-widget-title">{currentData.title}</h3>
        <ul class="list-group modern-list-group">
            {
                currentData.links.map((link) => (
                    <li class="list-group-item modern-list-item">
                        <a href={link.url}>{link.text}</a>
                        <span class="modern-badge">
                            <i class="fa-solid fa-chevron-right" />
                        </span>
                    </li>
                ))
            }
        </ul>
    </div>
    <!-- /.widget -->
</aside>
