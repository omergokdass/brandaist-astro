<script is:inline>
    // Dinamik kaydırma oku gösterimi
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".navbar .dropdown").forEach((dropdown) => {
            dropdown.addEventListener("mouseenter", () => {
                const submenus = dropdown.querySelectorAll(".dropdown-menu");
                submenus.forEach((menu) => {
                    // Check if it's actually overflowing
                    if (menu.scrollHeight > menu.clientHeight) {
                        menu.classList.add("is-overflowing");
                    } else {
                        menu.classList.remove("is-overflowing");
                    }
                });
            });
        });
    });
</script>

<style>
    @media (min-width: 1200px) {
        .navbar-nav .nav-link {
            padding-left: 8px !important;
            padding-right: 8px !important;
            font-size: 16px !important;
            font-weight: 700;
        }
    }

    /* Sticky Navbar Styling */
    :global(.navbar) {
        transition:
            background-color 0.3s ease,
            box-shadow 0.3s ease,
            backdrop-filter 0.3s ease;
    }
    :global(.navbar.nav-sticky) {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        z-index: 1050 !important;
        background-color: rgba(0, 0, 0, 0.75) !important;
        backdrop-filter: blur(10px) !important;
        -webkit-backdrop-filter: blur(10px) !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3) !important;
    }

    /* Long Dropdown scroll containment without visible scrollbars */
    :global(.navbar .dropdown-menu::before) {
        display: none !important; /* Optional: Remove bootstrap arrow if it clashes */
    }
    :global(.navbar .dropdown-menu) {
        max-height: 85vh;
        overflow-y: auto;
        overscroll-behavior: contain;
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE and Edge */
        position: relative;
    }
    :global(.navbar .dropdown-menu::-webkit-scrollbar) {
        display: none; /* Chrome, Safari and Opera */
    }

    /* Gelişmiş Kaydırma Oku Tasarımı (Sadece Taştığında) */
    :global(.navbar .dropdown-menu.is-overflowing::after) {
        content: "▼";
        position: sticky;
        bottom: 0;
        display: block;
        width: 100%;
        height: 35px;
        line-height: 35px;
        text-align: center;
        background-color: #151515; /* Menü ile tam aynı renk */
        color: #fff; /* Orijinal menü yazıları gibi beyaz */
        font-size: 14px;
        pointer-events: none;
        z-index: 100;
    }

    /* Force all dropdown items to stay on a single line */
    :global(.navbar .dropdown-item),
    :global(.navbar .mega-menu-content a) {
        white-space: nowrap !important;
    }

    /* Enlarged and tightened main navigation links */
</style>
