<style>
    /* Hide scrollbar for Chrome, Safari and Opera in desktop dropdowns */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .no-scrollbar {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
    }
</style>

<script is:inline>
    // Vanilla JS for independent lightweight mobile menu behavior
    document.addEventListener("DOMContentLoaded", () => {
        const mobileMenuBtn = document.getElementById("mobile-menu-btn");
        const mobileMenuContainer = document.getElementById(
            "mobile-menu-container",
        );
        const menuIconOpen = document.getElementById("menu-icon-open");
        const menuIconClose = document.getElementById("menu-icon-close");
        const body = document.body;

        if (mobileMenuBtn && mobileMenuContainer) {
            mobileMenuBtn.addEventListener("click", () => {
                const isOpen =
                    !mobileMenuContainer.classList.contains("translate-x-full");

                if (isOpen) {
                    // Close menu
                    mobileMenuContainer.classList.add("translate-x-full");
                    menuIconOpen.classList.remove("hidden");
                    menuIconClose.classList.add("hidden");
                    body.classList.remove("overflow-hidden");
                } else {
                    // Open menu
                    mobileMenuContainer.classList.remove("translate-x-full");
                    menuIconOpen.classList.add("hidden");
                    menuIconClose.classList.remove("hidden");
                    body.classList.add("overflow-hidden");
                }
            });
        }

        // Accordion functionality for mobile submenus
        const toggles = document.querySelectorAll("[data-toggle]");
        toggles.forEach((toggle) => {
            toggle.addEventListener("click", () => {
                const targetId = toggle.getAttribute("data-toggle");
                const targetEl = document.getElementById(targetId);
                const icon = toggle.querySelector("svg");

                if (targetEl.classList.contains("hidden")) {
                    targetEl.classList.remove("hidden");
                    icon.classList.add("rotate-180");
                } else {
                    targetEl.classList.add("hidden");
                    icon.classList.remove("rotate-180");
                }
            });
        });

        // Navbar scroll effect
        const navbar = document.getElementById("main-navbar");
        window.addEventListener("scroll", () => {
            if (window.scrollY > 20) {
                navbar.classList.add(
                    "bg-gray-900",
                    "shadow-xl",
                    "backdrop-blur-md",
                );
            } else {
                navbar.classList.remove(
                    "bg-gray-900",
                    "shadow-xl",
                    "backdrop-blur-md",
                );
            }
        });
    });
</script>
