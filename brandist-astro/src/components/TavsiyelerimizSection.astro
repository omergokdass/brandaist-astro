---

---

<section
    class="bg-gray-900 py-20 lg:py-28"
    aria-labelledby="tavsiyelerimiz-baslik"
>
    <div class="container mx-auto px-4 lg:px-8">
        <h2
            id="urunlerimiz-baslik"
            class="text-3xl md:text-4xl lg:text-5xl font-bold text-center text-white mb-6 tracking-tight"
        >
            Öne Çıkan Ürünlerimiz
        </h2>
        <p
            class="text-lg md:text-xl text-gray-400 text-center max-w-3xl mx-auto mb-16 leading-relaxed"
        >
            Amir Branda'nın en çok tercih edilen gölgelendirme ve çadır
            sistemlerini inceleyin. Tüm model seçenekleri için
            <a
                href="/urunler"
                class="text-primary font-bold hover:text-white transition-colors border-b border-primary hover:border-white pb-0.5"
                >Ürünler</a
            >
            sayfamızı ziyaret edebilirsiniz.
        </p>

        <!-- CSS Grid Yapısı (Performans dostu, %100 JavaScript'siz) -->
        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10"
        >
            <!-- Ürün 1 -->
            <a
                href="/pergola-tente"
                class="block relative group overflow-hidden rounded-2xl shadow-xl aspect-[3/4]"
            >
                <img
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                    src="/style/brand/img/motorlu-bioklimatik-pergola-fiyatlari.webp"
                    alt="Led ışıklı motorlu alüminyum otomatik pergola"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                >
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                    <h3
                        class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors"
                    >
                        Pergola Tente
                    </h3>
                    <p
                        class="text-gray-300 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"
                    >
                        Her mevsim kullanışlı, otomatik altyapı.
                    </p>
                </div>
            </a>

            <!-- Ürün 2 -->
            <a
                href="/seffaf-branda"
                class="block relative group overflow-hidden rounded-2xl shadow-xl aspect-[3/4]"
            >
                <img
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                    src="/style/brand/img/bahce.webp"
                    alt="Kafe ve restoranlar için şeffaf kış bahçesi"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                >
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                    <h3
                        class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors"
                    >
                        Şeffaf Branda Balkon
                    </h3>
                    <p
                        class="text-gray-300 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"
                    >
                        İşletmeler için izoleli ve net manzara.
                    </p>
                </div>
            </a>

            <!-- Ürün 3 -->
            <a
                href="/depo-cadiri"
                class="block relative group overflow-hidden rounded-2xl shadow-xl aspect-[3/4]"
            >
                <img
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                    src="/style/brand/img/istanbul-endustriyel-santiye-depo-cadiri.webp"
                    alt="Geniş hacimli çelik konstrüksiyonlu depo çadırı"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                >
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                    <h3
                        class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors"
                    >
                        10x10 Depo Çadırı
                    </h3>
                    <p
                        class="text-gray-300 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"
                    >
                        Fabrikalar için pratik stok depolama.
                    </p>
                </div>
            </a>

            <!-- Ürün 4 -->
            <a
                href="/mafsalli-tente"
                class="block relative group overflow-hidden rounded-2xl shadow-xl aspect-[3/4]"
            >
                <img
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                    src="/style/brand/img/ucuz-mafsalli-tente-modelleri-istanbul.webp"
                    alt="Dükkan önü manuel mafsallı tente modeli"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                >
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                    <h3
                        class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors"
                    >
                        Mafsallı Tente
                    </h3>
                    <p
                        class="text-gray-300 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"
                    >
                        Dükkan ve balkonlar için klasik model.
                    </p>
                </div>
            </a>

            <!-- Ürün 5 -->
            <a
                href="/motorlu-tente"
                class="block relative group overflow-hidden rounded-2xl shadow-xl aspect-[3/4]"
            >
                <img
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                    src="/style/brand/img/bioklimatik-tente.webp"
                    alt="Modern motorlu otomatik tente uygulaması"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                >
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                    <h3
                        class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors"
                    >
                        Motorlu Tente
                    </h3>
                    <p
                        class="text-gray-300 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"
                    >
                        Kumandalı özel led kurgusu.
                    </p>
                </div>
            </a>

            <!-- Ürün 6 -->
            <a
                href="/cadir"
                class="block relative group overflow-hidden rounded-2xl shadow-xl aspect-[3/4]"
            >
                <img
                    class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                    src="/style/brand/img/depo-cadiri.webp"
                    alt="Geniş kapasiteli özel ölçü çadır modelleri"
                    loading="lazy"
                    decoding="async"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                >
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                    <h3
                        class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors"
                    >
                        Özel Ölçü Çadır
                    </h3>
                    <p
                        class="text-gray-300 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100"
                    >
                        Tam korumalı geniş hangar alanı.
                    </p>
                </div>
            </a>
        </div>

        <div class="mt-20 text-center">
            <a
                href="/urunler"
                class="inline-block bg-primary text-white font-bold text-lg px-8 py-4 rounded-xl shadow-[0_4px_15px_rgba(76,166,229,0.3)] hover:bg-blue-600 hover:-translate-y-1 hover:shadow-[0_6px_20px_rgba(76,166,229,0.4)] transition-all duration-300"
            >
                Tüm Ürün Kataloğumuzu İnceleyin
            </a>
        </div>
    </div>
</section>
