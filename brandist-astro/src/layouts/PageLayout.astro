---
import Layout from "./Layout.astro";
import Sidebar from "../components/Sidebar.astro";

export interface Props {
    title: string;
    description: string;
    ogTitle?: string;
    ogImage?: string;
    ogType?: string;
    headerTitle: string;
    headerTitleTag?: string;
    headerSubtitle?: string;
    headerBgImage?: string;
    sidebarCategory?:
        | "tente"
        | "branda"
        | "cadir"
        | "kumas"
        | "semsiye"
        | string;
    hideSidebar?: boolean;
    customCanonical?: string;
    schemaPriceLow?: string;
    schemaPriceHigh?: string;
    faqData?: { question: string; answer: string }[];
}

const {
    title,
    description,
    ogTitle,
    ogImage,
    ogType,
    headerTitle,
    headerTitleTag = "h1",
    headerSubtitle,
    headerBgImage = "",
    sidebarCategory,
    hideSidebar = false,
    customCanonical,
    schemaPriceLow,
    schemaPriceHigh,
    faqData,
} = Astro.props;
---

<Layout
    title={title}
    description={description}
    ogTitle={ogTitle}
    ogImage={ogImage}
    ogType={ogType}
    customCanonical={customCanonical}
    preloadImage={headerBgImage}
    schemaPriceLow={schemaPriceLow}
    schemaPriceHigh={schemaPriceHigh}
    faqData={faqData}
>
    <slot name="json-ld" />

    <div
        class="relative bg-gray-900 overflow-hidden isolate px-6 py-24 sm:py-32 lg:px-8"
    >
        <div class="mx-auto max-w-4xl text-center">
            {
                headerTitleTag === "h1" ? (
                    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
                        {headerTitle}
                    </h1>
                ) : (
                    <h2 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
                        {headerTitle}
                    </h2>
                )
            }
            {
                headerSubtitle && (
                    <div
                        class="mt-6 text-xl leading-8 text-gray-300 font-medium"
                        set:html={headerSubtitle}
                    />
                )
            }
        </div>
    </div>

    <div class="bg-gray-50 py-16 sm:py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div
                class={hideSidebar
                    ? "flex flex-col"
                    : "flex flex-col lg:flex-row gap-12"}
            >
                <main class={hideSidebar ? "w-full" : "w-full lg:w-2/3"}>
                    <div
                        class={hideSidebar
                            ? ""
                            : "bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-10 lg:p-12 mb-8"}
                    >
                        <slot />
                    </div>

                    {faqData && faqData.length > 0 && (
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-10 lg:p-12">
                            <h2 class="text-2xl font-bold text-gray-900 mb-6">Sıkça Sorulan Sorular</h2>
                            <div class="space-y-4">
                                {faqData.map((faq) => (
                                    <details class="group bg-gray-50 rounded-lg open:bg-white open:ring-1 open:ring-gray-200 open:shadow-sm transition-all">
                                        <summary class="flex cursor-pointer items-center justify-between p-4 sm:p-5 font-semibold text-gray-900">
                                            <span>{faq.question}</span>
                                            <span class="ml-4 flex-shrink-0 transition-transform duration-300 group-open:-rotate-180">
                                                <i class="fa-solid fa-chevron-down text-primary"></i>
                                            </span>
                                        </summary>
                                        <div class="px-4 pb-4 sm:px-5 sm:pb-5 text-gray-600 border-t border-gray-100 pt-3">
                                            <p>{faq.answer}</p>
                                        </div>
                                    </details>
                                ))}
                            </div>
                        </div>
                    )}
                </main>
                {
                    !hideSidebar && (
                        <aside class="w-full lg:w-1/3">
                            <Sidebar category={sidebarCategory as any} />
                        </aside>
                    )
                }
            </div>
        </div>
    </div>
</Layout>
