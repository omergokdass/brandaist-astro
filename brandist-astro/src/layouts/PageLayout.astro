---
import Layout from "./Layout.astro";
import Sidebar from "../components/Sidebar.astro";

export interface Props {
    title: string;
    description: string;
    ogTitle?: string;
    ogImage?: string;
    ogType?: string;
    headerTitle: string;
    headerTitleTag?: string;
    headerSubtitle?: string;
    headerBgImage?: string;
    sidebarCategory?:
        | "tente"
        | "branda"
        | "cadir"
        | "kumas"
        | "semsiye"
        | string;
    hideSidebar?: boolean;
    customCanonical?: string;
}

const {
    title,
    description,
    ogTitle,
    ogImage,
    ogType,
    headerTitle,
    headerTitleTag = "h1",
    headerSubtitle,
    headerBgImage = "/style/brand/img/kategori-arkasi-pp.webp",
    sidebarCategory,
    hideSidebar = false,
    customCanonical,
} = Astro.props;
---

<Layout
    title={title}
    description={description}
    ogTitle={ogTitle}
    ogImage={ogImage}
    ogType={ogType}
    customCanonical={customCanonical}
>
    <slot name="json-ld" />

    <div
        class="relative bg-gray-900 overflow-hidden isolate px-6 py-24 sm:py-32 lg:px-8"
    >
        <img
            src={headerBgImage}
            alt="Amir Branda Hizmetleri"
            class="absolute inset-0 -z-10 h-full w-full object-cover object-center opacity-40 mix-blend-multiply"
        />
        <div class="mx-auto max-w-4xl text-center">
            {
                headerTitleTag === "h1" ? (
                    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
                        {headerTitle}
                    </h1>
                ) : (
                    <h2 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
                        {headerTitle}
                    </h2>
                )
            }
            {
                headerSubtitle && (
                    <div
                        class="mt-6 text-xl leading-8 text-gray-300 font-medium"
                        set:html={headerSubtitle}
                    />
                )
            }
        </div>
    </div>

    <div class="bg-gray-50 py-16 sm:py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div
                class={hideSidebar
                    ? "flex flex-col"
                    : "flex flex-col lg:flex-row gap-12"}
            >
                <main class={hideSidebar ? "w-full" : "w-full lg:w-2/3"}>
                    <div
                        class={hideSidebar
                            ? ""
                            : "bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-10 lg:p-12"}
                    >
                        <slot />
                    </div>
                </main>
                {
                    !hideSidebar && (
                        <aside class="w-full lg:w-1/3">
                            <Sidebar category={sidebarCategory as any} />
                        </aside>
                    )
                }
            </div>
        </div>
    </div>
</Layout>
