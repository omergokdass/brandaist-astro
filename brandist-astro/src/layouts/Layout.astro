                        </div>
                        <!-- /column -->
                    </div>
                    <!-- /.row -->
                    <div class="space20"></div>
                    <p class="text-center">
                        &copy; 2026 Amir Branda. Tüm Hakları Saklıdır.
                    </p>
                </div>
                <!-- /.container -->
            </footer>
        </div>
        <!-- /.content-wrapper -->
        <script
            is:inline
            defer
            src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script
