---
import Navbar from "../components/Navbar.astro";

export interface Props {
    title?: string;
    description?: string;
    ogTitle?: string;
    ogImage?: string;
    ogType?: string;
}

const {
    title = "Amir Branda | En İyi Tente ve Branda Sistemleri",
    description = "İstanbul'un lider tente ve branda üreticisi Amir Branda ile mekanlarınızı dört mevsim yaşanabilir kılın.",
    ogTitle,
    ogImage = "https://branda.ist/images/amir-branda-logo.jpg",
    ogType = "website",
} = Astro.props;

const pageTitle = title.includes("Amir Branda")
    ? title
    : `${title} | Amir Branda`;
const canonicalURL = new URL(
    Astro.url.pathname,
    Astro.site || "https://branda.ist",
);
const finalOgTitle = ogTitle || pageTitle;

// Breadcrumb Schema Generator
const pathname = Astro.url.pathname;
const pathSegments = pathname.split("/").filter((p) => p);
const breadcrumbItems = pathSegments.map((segment, index) => {
    const isLast = index === pathSegments.length - 1;
    const url =
        "https://branda.ist/" + pathSegments.slice(0, index + 1).join("/");
    return {
        "@type": "ListItem",
        position: index + 2,
        name:
            isLast && title
                ? title.split("|")[0].trim()
                : segment
                      .replace(/-/g, " ")
                      .replace(/\b\w/g, (l) => l.toUpperCase()),
        item: url,
    };
});
const breadcrumbSchema =
    pathSegments.length > 0
        ? JSON.stringify({
              "@context": "https://schema.org",
              "@type": "BreadcrumbList",
              itemListElement: [
                  {
                      "@type": "ListItem",
                      position: 1,
                      name: "Ana Sayfa",
                      item: "https://branda.ist",
                  },
                  ...breadcrumbItems,
              ],
          })
        : null;

import "../styles/css/bootstrap.min.css";
import "../styles/css/plugins.css";

import "../styles/type/icons.css";
import "../styles/style.css";
import "../styles/css/color/sky.css";
import "../styles/css/font/font2.css";
---

<!doctype html>
<html lang="tr">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="author" content="Amir Branda" />
        <meta
            name="p:domain_verify"
            content="a43a0aadc77ffba033ea63078a933436"
        />
        <meta name="robots" content="index, follow" />
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
        <link
            rel="icon"
            type="image/png"
            sizes="192x192"
            href="/favicon.png?v=4"
        />
        <link rel="apple-touch-icon" sizes="192x192" href="/favicon.png?v=4" />
        <link rel="shortcut icon" href="/favicon.png?v=4" />
        <!-- Open Graph META -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={finalOgTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />

        <!-- Twitter META -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={finalOgTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <title>{pageTitle}</title>
        <link
            href="https://fonts.googleapis.com/css?family=EB+Garamond:400,400i,500,500i,600,600i,700,700i,800,800i"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
            integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
        />
        <style>
            /* Modern Floating Buttons */
            .floating-action-container {
                position: fixed;
                bottom: 30px; /* Brought back down to default since left side is clear */
                left: 20px; /* Moved to left */
                display: flex;
                flex-direction: column;
                align-items: flex-start; /* Keep buttons pinned to the left edge */
                gap: 15px;
                z-index: 9999;
            }

            .float-btn {
                display: flex;
                align-items: center;
                justify-content: flex-start; /* Align from left for slide animation */
                padding: 0; /* Remove padding to perfectly center 55x55 icon container */
                border-radius: 50px;
                color: #fff !important;
                font-family: "EB Garamond", sans-serif;
                font-size: 16px;
                font-weight: 600;
                text-decoration: none;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
                transition:
                    transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
                    box-shadow 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
                    width 0.4s ease;
                width: 55px; /* Initial circle width */
                height: 55px;
                overflow: hidden;
                white-space: nowrap;
            }

            .float-btn i {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 55px; /* Icon container exactly matches collapsed button */
                height: 55px;
                margin: 0;
                flex-shrink: 0; /* Prevent squishing */
            }

            .float-btn span {
                display: inline-block;
                max-width: 0;
                opacity: 0;
                transition:
                    opacity 0.3s ease,
                    transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
                transform: translateX(-10px); /* Subtle slide-in effect */
            }

            .float-btn:hover {
                box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
                color: #fff !important;
                width: 160px; /* Expanded width */
                padding-left: 20px; /* Breathing room for text when expanding right */
            }

            .float-btn:hover span {
                max-width: 100px;
                opacity: 1;
                transform: translateX(0); /* Settle into place */
            }

            .btn-whatsapp {
                background: linear-gradient(135deg, #25d366, #128c7e);
            }

            .btn-whatsapp i {
                font-size: 28px; /* Balanced icon size */
            }

            .btn-quote {
                background: linear-gradient(135deg, #007bff, #0056b3);
            }

            .btn-quote i {
                font-size: 22px; /* Slightly smaller because it's visually wider */
            }

            @media (max-width: 768px) {
                .float-btn span {
                    display: none !important; /* Never show text on mobile */
                }
                .float-btn:hover {
                    width: 55px;
                    padding-left: 0;
                }
                .floating-action-container {
                    bottom: 20px; /* Standard mobile clearance */
                    left: 15px;
                }
                .blog-card-img {
                    border-top-left-radius: 0.25rem;
                    border-top-right-radius: 0.25rem;
                    border-bottom-left-radius: 0 !important;
                    border-bottom-right-radius: 0 !important;
                }
                .navbar {
                    z-index: 1050 !important;
                }
                .navbar-collapse {
                    max-height: 80vh;
                    overflow-y: auto;
                    background-color: rgba(
                        52,
                        58,
                        64,
                        0.98
                    ); /* Solid dark background for menu */
                }
            }

            .blog-card-img {
                width: 100%;
                height: 220px;
                object-fit: cover;
                border-top-left-radius: 0.25rem;
                border-bottom-left-radius: 0.25rem;
            }
        </style>
        <script type="application/ld+json" is:inline>
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "name": "Amir Branda",
                "image": "https://branda.ist/style/brand/img/branda-logo.webp",
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Ayvansaray Mahallesi Esnaf Loncası Sokak No:27",
                    "addressLocality": "Fatih",
                    "addressRegion": "İstanbul",
                    "addressCountry": "TR"
                },
                "telephone": "+90 538 604 48 51",
                "url": "https://branda.ist",
                "sameAs": [
                    "https://www.facebook.com/amirbrandacadirtente/",
                    "https://www.instagram.com/branda.ist/",
                    "https://x.com/amirbrandaist",
                    "https://tr.pinterest.com/amirbranda/"
                ]
            }
        </script>
        {
            breadcrumbSchema && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={breadcrumbSchema}
                />
            )
        }
    </head>
    <body>
