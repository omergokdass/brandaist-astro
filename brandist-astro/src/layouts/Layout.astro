---
import Navbar from "../components/Navbar.astro";
import { ClientRouter } from "astro:transitions";

export interface Props {
    title?: string;
    description?: string;
    ogTitle?: string;
    ogImage?: string;
    ogType?: string;
    customCanonical?: string;
}

const {
    title = "Amir Branda | En İyi Tente ve Branda Sistemleri",
    description = "İstanbul'un lider tente ve branda üreticisi Amir Branda ile mekanlarınızı dört mevsim yaşanabilir kılın.",
    ogTitle,
    ogImage = "https://branda.ist/images/amir-branda-logo.jpg",
    ogType = "website",
    customCanonical,
} = Astro.props;

const pageTitle = title.includes("Amir Branda")
    ? title
    : `${title} | Amir Branda`;
const canonicalURL =
    customCanonical ||
    new URL(Astro.url.pathname, Astro.site || "https://branda.ist");
const finalOgTitle = ogTitle || pageTitle;

// Breadcrumb Schema Generator
const pathname = Astro.url.pathname;
const pathSegments = pathname.split("/").filter((p) => p);
const breadcrumbItems = pathSegments.map((segment, index) => {
    const isLast = index === pathSegments.length - 1;
    const url =
        "https://branda.ist/" + pathSegments.slice(0, index + 1).join("/");
    return {
        "@type": "ListItem",
        position: index + 2,
        name:
            isLast && title
                ? title.split("|")[0].trim()
                : segment
                      .replace(/-/g, " ")
                      .replace(/\b\w/g, (l) => l.toUpperCase()),
        item: url,
    };
});
const breadcrumbSchema =
    pathSegments.length > 0
        ? JSON.stringify({
              "@context": "https://schema.org",
              "@type": "BreadcrumbList",
              itemListElement: [
                  {
                      "@type": "ListItem",
                      position: 1,
                      name: "Ana Sayfa",
                      item: "https://branda.ist",
                  },
                  ...breadcrumbItems,
              ],
          })
        : null;

// LocalBusiness Schema (HomeAndConstructionBusiness)
const localBusinessSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    name: "Amir Branda",
    image: "https://branda.ist/style/brand/img/logo-amir-branda.png",
    "@id": "https://branda.ist",
    url: "https://branda.ist",
    telephone: "+905386044851",
    priceRange: "₺₺",
    address: {
        "@type": "PostalAddress",
        streetAddress: "İstanbul",
        addressLocality: "İstanbul",
        addressRegion: "TR",
        addressCountry: "TR",
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: 41.0082,
        longitude: 28.9784,
    },
    openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
        ],
        opens: "08:30",
        closes: "19:00",
    },
});

// Dynamic Service Schema for Product/Service Pages
const normalizedPath =
    pathname.endsWith("/") && pathname !== "/"
        ? pathname.slice(0, -1)
        : pathname;
const isServicePage =
    ![
        "/",
        "/iletisim",
        "/hakkimizda",
        "/hizmetler",
        "/urunler",
        "/fiyat-listesi",
        "/gizlilik-ve-cerez-politikasi",
        "/kvkk-aydinlatma-metni",
        "/sikca-sorulan-sorular",
        "/blog",
    ].includes(normalizedPath) && !pathname.startsWith("/blog/");

const serviceSchema = isServicePage
    ? JSON.stringify({
          "@context": "https://schema.org/",
          "@type": "Service",
          serviceType: title.split("|")[0].trim(),
          provider: {
              "@type": "HomeAndConstructionBusiness",
              name: "Amir Branda",
              image: "https://branda.ist/style/brand/img/logo-amir-branda.png",
              url: "https://branda.ist",
              telephone: "+905386044851",
          },
          areaServed: {
              "@type": "City",
              name: "\u0130stanbul",
          },
          description: description,
          offers: {
              "@type": "AggregateOffer",
              priceCurrency: "TRY",
              lowPrice: "100",
              highPrice: "50000",
              offerCount: "1",
          },
      })
    : null;
import "../styles/global.css";
---

<!doctype html>
<html lang="tr" class="overflow-x-hidden w-full">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <ClientRouter />
        <meta name="author" content="Amir Branda" />
        <meta
            name="p:domain_verify"
            content="a43a0aadc77ffba033ea63078a933436"
        />
        <meta name="robots" content="index, follow" />
        <meta name="description" content={description} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonicalURL} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
        <link
            rel="icon"
            type="image/png"
            sizes="192x192"
            href="/favicon.png?v=4"
        />
        <link rel="apple-touch-icon" sizes="192x192" href="/favicon.png?v=4" />
        <link rel="shortcut icon" href="/favicon.png?v=4" />
        <!-- Open Graph META -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={finalOgTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />

        <!-- Twitter META -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={finalOgTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <title>{pageTitle}</title>

        <!-- SEO Structured Data (JSON-LD) -->
        {
            breadcrumbSchema && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={breadcrumbSchema}
                />
            )
        }
        {
            localBusinessSchema && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={localBusinessSchema}
                />
            )
        }
        {
            serviceSchema && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={serviceSchema}
                />
            )
        }

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preconnect"
            href="https://cdnjs.cloudflare.com"
            crossorigin
        />
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
        <link
            rel="preload"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/webfonts/fa-solid-900.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/webfonts/fa-brands-400.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="preload"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
                crossorigin="anonymous"
                referrerpolicy="no-referrer"
            />
        </noscript>
        <!-- Swiper CSS -->
        <link rel="stylesheet" href="/style/css/swiper-bundle.min.css" />
        <style>
            /* Modern Floating Buttons */
            .floating-action-container {
                position: fixed;
                bottom: 30px; /* Brought back down to default since left side is clear */
                left: 20px; /* Moved to left */
                display: flex;
                flex-direction: column;
                align-items: flex-start; /* Keep buttons pinned to the left edge */
                gap: 15px;
                z-index: 1040; /* Reduced to be below the mobile menu (1050) */
            }

            .float-btn {
                display: flex;
                align-items: center;
                justify-content: flex-start; /* Align from left for slide animation */
                padding: 0; /* Remove padding to perfectly center 55x55 icon container */
                border-radius: 50px;
                color: #fff !important;
                font-family: "EB Garamond", sans-serif;
                font-size: 16px;
                font-weight: 600;
                text-decoration: none;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
                transition:
                    transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
                    box-shadow 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
                    width 0.4s ease;
                width: 55px; /* Initial circle width */
                height: 55px;
                overflow: hidden;
                white-space: nowrap;
            }

            .float-btn i {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 55px; /* Icon container exactly matches collapsed button */
                height: 55px;
                margin: 0;
                flex-shrink: 0; /* Prevent squishing */
            }

            .float-btn span {
                display: inline-block;
                max-width: 0;
                opacity: 0;
                transition:
                    opacity 0.3s ease,
                    transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
                transform: translateX(-10px); /* Subtle slide-in effect */
            }

            .float-btn:hover {
                box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
                color: #fff !important;
                width: 160px; /* Expanded width */
                padding-left: 20px; /* Breathing room for text when expanding right */
            }

            .float-btn:hover span {
                max-width: 100px;
                opacity: 1;
                transform: translateX(0); /* Settle into place */
            }

            .btn-whatsapp {
                background: linear-gradient(135deg, #25d366, #128c7e);
            }

            .btn-whatsapp i {
                font-size: 28px; /* Balanced icon size */
            }

            .btn-quote {
                background: linear-gradient(135deg, #007bff, #0056b3);
            }

            .btn-quote i {
                font-size: 22px; /* Slightly smaller because it's visually wider */
            }

            @media (max-width: 991.98px) {
                .float-btn span {
                    display: none !important; /* Never show text on mobile */
                }
                .float-btn:hover {
                    width: 55px;
                    padding-left: 0;
                }
                .floating-action-container {
                    bottom: 20px; /* Standard mobile clearance */
                    left: 15px;
                }
                .blog-card-img {
                    border-top-left-radius: 0.25rem;
                    border-top-right-radius: 0.25rem;
                    border-bottom-left-radius: 0 !important;
                    border-bottom-right-radius: 0 !important;
                }
            }

            .blog-card-img {
                width: 100%;
                height: 220px;
                object-fit: cover;
                border-top-left-radius: 0.25rem;
                border-bottom-left-radius: 0.25rem;
            }
        </style>
        <script type="application/ld+json" is:inline>
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "name": "Amir Branda",
                "image": "https://branda.ist/style/brand/img/branda-logo.webp",
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Ayvansaray Mahallesi Esnaf Loncası Sokak No:27",
                    "addressLocality": "Fatih",
                    "addressRegion": "İstanbul",
                    "addressCountry": "TR"
                },
                "telephone": "+90 538 604 48 51",
                "url": "https://branda.ist",
                "sameAs": [
                    "https://www.facebook.com/amirbrandacadirtente/",
                    "https://www.instagram.com/branda.ist/",
                    "https://x.com/amirbrandaist",
                    "https://tr.pinterest.com/amirbranda/"
                ]
            }
        </script>
        {
            breadcrumbSchema && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={breadcrumbSchema}
                />
            )
        }
    </head>
    <body class="overflow-x-hidden w-full m-0 p-0">
        <div class="floating-action-container">
            <a href="/iletisim" class="float-btn btn-quote">
                <i class="fa-solid fa-file-invoice-dollar"></i>
                <span>Teklif Alın</span>
            </a>
            <a
                href="https://api.whatsapp.com/send?phone=905386044851"
                class="float-btn btn-whatsapp"
                target="_blank"
            >
                <i class="fa-brands fa-whatsapp"></i>
                <span>WhatsApp</span>
            </a>
        </div>
        <div class="content-wrapper">
            <Navbar />
            <main id="main-content">
                <slot />
            </main>
            <footer
                class="bg-gray-900 border-t border-gray-800 text-gray-400 py-14"
            >
                <div class="container mx-auto px-4 lg:px-8">
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8 text-center lg:text-left"
                    >
                        <!-- Konum -->
                        <div>
                            <h3
                                class="text-lg font-bold text-white mb-4 uppercase tracking-wider relative inline-block pb-2 border-b-2 border-primary"
                            >
                                Konum
                            </h3>
                            <address class="not-italic mt-2">
                                <a
                                    href="https://maps.app.goo.gl/hVhqkTaVXen2EfRM9"
                                    target="_blank"
                                    class="hover:text-primary transition-colors block leading-relaxed"
                                >
                                    Ayvansaray Mahallesi Esnaf Loncası Sokak
                                    No:27, Fatih / İstanbul
                                </a>
                            </address>
                        </div>

                        <!-- Kurumsal -->
                        <div>
                            <h3
                                class="text-lg font-bold text-white mb-4 uppercase tracking-wider relative inline-block pb-2 border-b-2 border-primary"
                            >
                                Kurumsal
                            </h3>
                            <ul class="space-y-2">
                                <li>
                                    <a
                                        href="/istanbul-tenteci"
                                        class="hover:text-primary transition-colors block font-bold"
                                        >İstanbul Tenteci</a
                                    >
                                </li>
                                <li>
                                    <a
                                        href="/hakkimizda"
                                        class="hover:text-primary transition-colors block"
                                        >Hakkımızda</a
                                    >
                                </li>
                                <li>
                                    <a
                                        href="/sikca-sorulan-sorular"
                                        class="hover:text-primary transition-colors block"
                                        >Sıkça Sorulan Sorular</a
                                    >
                                </li>
                                <li>
                                    <a
                                        href="/blog"
                                        class="hover:text-primary transition-colors block"
                                        >Blog / Faydalı Bilgiler</a
                                    >
                                </li>
                                <li>
                                    <a
                                        href="/fiyat-listesi"
                                        class="hover:text-primary transition-colors block"
                                        >Fiyat Listesi</a
                                    >
                                </li>
                                <li>
                                    <a
                                        href="/kvkk-aydinlatma-metni"
                                        class="hover:text-primary transition-colors block"
                                        >KVKK Aydınlatma Metni</a
                                    >
                                </li>
                                <li>
                                    <a
                                        href="/gizlilik-ve-cerez-politikasi"
                                        class="hover:text-primary transition-colors block"
                                        >Gizlilik ve Çerez Politikası</a
                                    >
                                </li>
                            </ul>
                        </div>

                        <!-- Social Media -->
                        <div>
                            <h3
                                class="text-lg font-bold text-white mb-4 uppercase tracking-wider relative inline-block pb-2 border-b-2 border-primary"
                            >
                                Bizi Takip Edin
                            </h3>
                            <ul
                                class="flex justify-center lg:justify-start space-x-3 mt-2"
                            >
                                <li>
                                    <a
                                        href="https://tr.pinterest.com/amirbranda/"
                                        target="_blank"
                                        class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-800 hover:bg-primary hover:text-white transition-all duration-300"
                                    >
                                        <i
                                            class="fa-brands fa-pinterest text-lg"
                                        ></i>
                                    </a>
                                </li>
                                <li>
                                    <a
                                        href="https://www.facebook.com/amirbrandacadirtente/"
                                        target="_blank"
                                        class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-800 hover:bg-blue-600 hover:text-white transition-all duration-300"
                                    >
                                        <i
                                            class="fa-brands fa-facebook-f text-lg"
                                        ></i>
                                    </a>
                                </li>
                                <li>
                                    <a
                                        href="https://www.instagram.com/branda.ist/"
                                        target="_blank"
                                        class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-800 hover:bg-pink-600 hover:text-white transition-all duration-300"
                                    >
                                        <i
                                            class="fa-brands fa-instagram text-lg"
                                        ></i>
                                    </a>
                                </li>
                                <li>
                                    <a
                                        href="https://x.com/amirbrandaist"
                                        target="_blank"
                                        class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-800 hover:text-white transition-all duration-300"
                                    >
                                        <i
                                            class="fa-brands fa-x-twitter text-lg"
                                        ></i>
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <!-- İletişim -->
                        <div>
                            <h3
                                class="text-lg font-bold text-white mb-4 uppercase tracking-wider relative inline-block pb-2 border-b-2 border-primary"
                            >
                                İletişim
                            </h3>
                            <div class="space-y-2">
                                <a
                                    href="mailto:amirbranda@hotmail.com"
                                    class="hover:text-primary transition-colors block"
                                    >amirbranda@hotmail.com</a
                                >
                                <a
                                    href="tel:+902125330891"
                                    class="hover:text-primary transition-colors block"
                                    >0 212 533 08 91</a
                                >
                                <a
                                    href="tel:+905386044851"
                                    class="hover:text-primary transition-colors font-bold text-white text-lg block mt-2"
                                    >0 538 604 48 51</a
                                >
                            </div>
                        </div>
                    </div>

                    <div
                        class="border-t border-gray-800 pt-6 mt-2 text-center text-sm text-gray-500"
                    >
                        <p>&copy; 2026 Amir Branda. Tüm Hakları Saklıdır.</p>
                    </div>
                </div>
            </footer>
        </div>
        <!-- /.content-wrapper -->

        <!-- Swiper JS -->
        <script is:inline defer src="/style/js/swiper-bundle.min.js"></script>

        <slot name="extra-scripts" />
    </body>
</html>
