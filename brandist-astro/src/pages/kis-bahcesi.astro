                                },
                                {
                                    src: "/style/brand/img/seffaf-kis-bahcesi-brandasi.webp",
                                    alt: "Şeffaf kış bahçesi mika kapama 2",
                                },
                                {
                                    src: "/style/brand/img/seffaf-branda8.webp",
                                    alt: "Şeffaf kış bahçesi mika kapama 3",
                                },
                            ]}
                        />
                    </div>
                </div>
                <!-- /.container -->
            </div>
            <!-- /.social -->
        </div>
        <!-- /.post-content -->
    </article>
    <!-- /.post -->
</PageLayout>
