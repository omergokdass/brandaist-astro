---
import Layout from "../layouts/Layout.astro";
import TestimonialSlider from "../components/TestimonialSlider.astro";
---

<Layout
    title="İstanbul Branda Firmaları | Tente ve Branda İmalatı | Amir Branda"
    description="İstanbul'un lider tente imalatçısı Amir Branda. Mafsallı tente, kış bahçesi, ucuz çadır ve şeffaf branda imalatında güvenilir yılların tecrübesi."
    ogTitle="İstanbul Branda Firmaları | Tente İmalatı | Amir Branda"
>
    <div
        class="wrapper image-wrapper bg-image inverse-text"
        style="background-image: url('/style/brand/img/kategori-arkasi-pp.webp');"
    >
        <div class="container inner pt-120 pb-120 text-center">
            <h2 class="heading mb-0"></h2>
        </div>
        <!-- /.container -->
    </div>
    <!-- /.wrapper -->
    <div class="wrapper light-wrapper">
        <div class="container inner">
            <h2 class="section-title mb-40 text-center">
                Tüm Bunların Arkasında Kim Var?
            </h2>
            <div class="row">
                <div class="col-lg-6 text-md-center">
                    <figure>
                        <img
                            class="w-100 img-fluid rounded mb-3 shadow-sm"
                            style="max-height: 480px; object-fit: cover;"
                            src="/style/brand/img/branda-logo.webp"
                            alt="Amir Branda Tente ve Çadır Sistemleri"
                            loading="lazy"
                        />
                    </figure>
                </div>
                <!-- /column -->
                <div class="space30 d-block d-lg-none d-xl-none"></div>
                <div class="col-lg-6">
                    <h1 class="h3 mb-3">
                        İstanbul'un En Güvenilir Tente Tente ve Branda
                        İmalatçısı: Amir Branda
                    </h1>
                    <p>
                        Amir Branda, 2009 yılından bu yana İstanbul başta olmak
                        üzere tüm Türkiye'de ve yurt dışında birinci sınıf <strong
                            >branda imalatı</strong
                        > yaparak müşterilerine kalıcı ve teknolojik sistemler sunmaktadır.
                        Sektördeki en köklü <strong
                            >İstanbul branda firmaları</strong
                        > arasında yerini alan atölyemiz, kafe ve restoranlardan sanayi
                        kuruluşlarına kadar her ihtiyaca özel hızlı çözümler üretmektedir.
                    </p>

                    <h2 class="h5 mb-2 mt-4">
                        Neden Biz? Tente ve Çadır Sistemlerindeki Uzmanlığımız
                    </h2>
                    <blockquote class="bordered">
                        <p>
                            <a
                                href="/mafsalli-tente"
                                class="text-primary font-weight-bold"
                                title="Mafsallı tente">Mafsallı tente</a
                            >, şeffaf <a
                                href="/kis-bahcesi"
                                class="text-primary font-weight-bold"
                                title="kış bahçesi">kış bahçesi</a
                            > kapama, motorlu pergola, oto ve <strong
                                >kamyon brandası fiyatları</strong
                            > konusundaki avantajlarımız ve devasa endüstriyel <strong
                                >çadır sistemleri fiyat</strong
                            > politikamızla sektördeki kalıpları yıkıyoruz. <strong
                                >En ucuz branda fiyatları</strong
                            > ile en yüksek kaliteyi harmanlıyoruz.
                        </p>
                        <footer class="blockquote-footer">
                            Amir Branda Teknik Ekip liderleri
                        </footer>
                    </blockquote>

                    <h2 class="h5 mb-2">
                        İstanbul Tente İmalatçısı Olarak Misyonumuz
                    </h2>
                    <p>
                        Müşteri memnuniyetini merkeze alan firmamız, sadece
                        satış odaklı değil, uzun yıllar dayanacak, paslanmaz
                        sistemler üreterek müşteri bütçesini korumayı amaçlar.
                        Uzman personelimiz ile <strong
                            >İstanbul tente imalatçısı</strong
                        > sıfatımızı koruyarak ücretsiz keşif avantajları sunuyoruz.
                        Sektördeki rakiplerimizin aksine, biz sadece standart ölçüler
                        değil, mimari projenize tam uygun, milimetrik hesaplamalarla
                        yapılmış özel tasarımlar geliştiririz. Geniş ve güncel <strong
                            >branda fiyat listesi</strong
                        > seçeneklerimizle herkesin kaliteli bir koruma sistemine
                        sahip olmasını sağlıyoruz.
                    </p>

                    <p class="font-weight-600">
                        Dış mekanlarınıza gölge, işletmenize değer,
                        hayallerinize ise yepyeni bir atmosfer katan modern
                        branda ve çadır sistemlerimizle vakit kaybetmeden
                        tanışın!
                    </p>
                    <ul class="social social-color social-s mb-15">
                        <li>
                            <a
                                href="https://www.facebook.com/amirbrandacadirtente/"
                                target="_blank"
                                ><i class="fa-brands fa-facebook-f"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://tr.pinterest.com/amirbranda/"
                                target="_blank"
                                ><i class="fa-brands fa-pinterest"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://www.instagram.com/branda.ist/"
                                target="_blank"
                                ><i class="fa-brands fa-instagram"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://x.com/amirbrandaist"
                                target="_blank"
                                ><i class="fa-brands fa-twitter"></i></a
                            >
                        </li>
                    </ul>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </div>
    <!-- /.wrapper -->
    <TestimonialSlider />
</Layout>
