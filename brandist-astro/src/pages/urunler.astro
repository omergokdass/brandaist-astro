---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
    title="Tüm Ürünler ve Tente Branda Çeşitleri | Amir Branda"
    description="Amir Branda'nın ürettiği tüm tente sistemleri, kış bahçesi, şeffaf branda, kamyonet çadırları ve pergola modelleri kataloğu. Tüm ürünleri inceleyin."
    ogTitle="Tüm Ürünler ve Tente Branda Çeşitleri | Amir Branda"
    ogImage="https://branda.ist/style/brand/img/pergola-tente1.webp"
    headerTitle="Sizin Mekanınıza En Uygun Çözümü Seçin"
    headerTitleTag="h2"
    headerBgImage="/style/brand/img/kategori-arkasi-pp.webp"
    sidebarCategory="tente"
>
    <script slot="json-ld" type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org/",
            "@type": "ItemList",
            "name": "Amir Branda Ürün Kataloğu",
            "description": "Tüm ürün kategorilerimizi ve modellerimizi içeren liste.",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Mafsallı Tente",
                    "url": "https://branda.ist/mafsalli-tente"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Pergola Tente",
                    "url": "https://branda.ist/pergola-tente"
                },
                {
                    "@type": "ListItem",
                    "position": 3,
                    "name": "Şeffaf Kış Bahçesi",
                    "url": "https://branda.ist/seffaf-branda"
                },
                {
                    "@type": "ListItem",
                    "position": 4,
                    "name": "Depo Çadırı",
                    "url": "https://branda.ist/depo-cadiri"
                }
            ]
        }
    </script>
    <article class="post">
        <h1 class="post-title text-center mb-4" id="page">
            Geniş Ürün Kataloğumuz
        </h1>
        <div class="post-content">
            <div class="seo-content text-center mb-5 max-w-700 mx-auto">
                <p
                    class="lead"
                    style="font-size: 1.15rem; color: #555; line-height: 1.8;"
                >
                    İstanbul'un lider <strong
                        ><a
                            href="/branda-tente-imalati"
                            class="text-primary font-weight-bold"
                            title="branda imalatı">brandacı ve tentecisi</a
                        ></strong
                    >
                    Amir Branda güvencesi ile sunulan, mekanınıza estetik, değer ve
                    dört mevsim konfor katan tüm gölgelendirme sistemlerimizi inceleyebilirsiniz.
                    Modern evlerden ağır endüstriyel tesislere kadar her talebe uygun,
                    garantili üretim yapıyoruz.
                </p>
            </div>

            <!-- Kategori 1: Tente Sistemleri -->
            <div class="category-section mt-5">
                <div class="text-center mb-5">
                    <h2 class="display-6 font-weight-bold mb-3">
                        Tente ve Gölgelendirme Sistemleri
                    </h2>
                    <hr
                        class="w-10 mx-auto mb-4 border-2 border-primary"
                        style="width: 60px; border-top: 3px solid #4c86e5; border-radius: 5px;"
                    />
                    <p class="text-muted">
                        Güneşin kavurucu sıcaklarından ve yağmurdan en şık
                        şekilde korunun.
                    </p>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <!-- Pergola -->
                    <div class="col mb-4">
                        <div class="product-card">
                            <div class="product-badge bg-danger">
                                En Çok Satan
                            </div>
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/pergola-tente1.webp"
                                    class="img-fluid"
                                    alt="Pergola Tente Sistemleri"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Pergola Tente
                                </h3>
                                <p class="text-muted small">
                                    Kumandalı, açılır-kapanır LED aydınlatmalı
                                    dört mevsim lüks tavan sistemleri. Kafe ve
                                    teraslar için idealdir.
                                </p>
                                <a href="/pergola-tente" class="btn-product"
                                    >Detaylı İncele <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Bioklimatik -->
                    <div class="col mb-4">
                        <div class="product-card">
                            <div class="product-badge bg-dark">
                                Premium Sistem
                            </div>
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/bioklimatik-tente.webp"
                                    class="img-fluid"
                                    alt="Bioklimatik Pergola Sistemleri"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Bioklimatik Tente
                                </h3>
                                <p class="text-muted small">
                                    Alüminyum panelleri ekseni etrafında dönerek
                                    doğal havalandırma sağlayan, %100 su
                                    yalıtımlı mimari sistem.
                                </p>
                                <a href="/bioklimatik-tente" class="btn-product"
                                    >Detaylı İncele <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Mafsallı -->
                    <div class="col mb-4">
                        <div class="product-card">
                            <div class="product-badge bg-primary">Ekonomik</div>
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/ucuz-mafsalli-tente-modelleri-istanbul.webp"
                                    class="img-fluid"
                                    alt="Mafsallı Tenteler"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Mafsallı Tente
                                </h3>
                                <p class="text-muted small">
                                    Mağaza vitrinleri, bakkallar ve düz
                                    balkonlar için tasarlanmış eklemli (kollu)
                                    ve çevirmeli pratik gölgelendirme.
                                </p>
                                <a href="/mafsalli-tente" class="btn-product"
                                    >Detaylı İncele <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Kasetli -->
                    <div class="col mb-4">
                        <div class="product-card">
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/karpuz-tente1.webp"
                                    class="img-fluid"
                                    alt="Kasetli Tenteler"
                                    loading="lazy"
                                    style="filter: grayscale(20%);"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Kasetli Tente
                                </h3>
                                <p class="text-muted small">
                                    Kapandığı zaman kumaşı ve mekanizmayı
                                    tamamen alüminyum bir kutu (kaset) içine
                                    saklayan modern tente varyasyonu.
                                </p>
                                <a href="/kasetli-tente" class="btn-product"
                                    >Detaylı İncele <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Zip Tente -->
                    <div class="col mb-4">
                        <div class="product-card">
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/seffaf-branda.webp"
                                    class="img-fluid"
                                    alt="Zip Perde ve Dikey Tente"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Zip Tente (Düşey Tente)
                                </h3>
                                <p class="text-muted small">
                                    Fermuarlı ray sistemi ile rüzgara tam
                                    dayanıklı, motorlu dikey yalıtım perdesi.
                                    Kış bahçeleri için tamamlayıcıdır.
                                </p>
                                <a href="/zip-tente" class="btn-product"
                                    >Detaylı İncele <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Karpuz Tente -->
                    <div class="col mb-4">
                        <div class="product-card">
                            <div class="product-badge bg-info text-white">
                                Butik Tasarım
                            </div>
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/karpuz-tente1.webp"
                                    class="img-fluid"
                                    alt="Dekoratif Karpuz Tente"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Karpuz & Sabit Tente
                                </h3>
                                <p class="text-muted small">
                                    Oteller, pastaneler ve pencereler için
                                    vitrine şirinlik katan, sabit veya ipli oval
                                    (karpuz dilimli) tenteler.
                                </p>
                                <div
                                    class="d-flex flex-column mt-auto pt-2"
                                    style="gap: 8px;"
                                >
                                    <a
                                        href="/karpuz-tente"
                                        class="btn-product m-0"
                                        >Karpuz Modelleri <span>→</span></a
                                    >
                                    <a
                                        href="/sabit-tente"
                                        class="btn-product m-0"
                                        >Sabit Modeller <span>→</span></a
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="space50"></div>

            <!-- Kategori 2: Çadır ve Endüstriyel Sİstemler -->
            <div
                class="category-section mt-5 bg-light px-4 py-5"
                style="border-radius: 12px;"
            >
                <div class="text-center mb-5">
                    <h2 class="display-6 font-weight-bold mb-3">
                        Çadır ve Endüstriyel Kapamalar
                    </h2>
                    <hr
                        class="w-10 mx-auto mb-4 border-2 border-primary"
                        style="width: 60px; border-top: 3px solid #4c86e5; border-radius: 5px;"
                    />
                    <p class="text-muted">
                        Ağır hava koşullarına dayanıklı, geniş açıklıkları
                        kaplayan profesyonel çadır mimarileri.
                    </p>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <!-- Şeffaf Kış Bahçesi -->
                    <div class="col mb-4">
                        <div class="product-card bg-white">
                            <div class="product-badge bg-success">
                                Yüksek İlgi
                            </div>
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/seffaf-kis-bahcesi-brandasi.webp"
                                    class="img-fluid"
                                    alt="Şeffaf Kış Bahçesi"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Şeffaf Kış Bahçesi
                                </h3>
                                <p class="text-muted small">
                                    0.80mm PVC mika malzeme ile işletmenizin
                                    açık alanlarını ısı izolasyonlu kapalı
                                    odalara çevirin.
                                </p>
                                <a href="/seffaf-branda" class="btn-product"
                                    >Tüm Modelleri Gör <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Depo Çadırı -->
                    <div class="col mb-4">
                        <div class="product-card bg-white">
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/depo-cadiri.webp"
                                    class="img-fluid"
                                    alt="Depo Çadırları"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Şantiye & Depo Çadırı
                                </h3>
                                <p class="text-muted small">
                                    Sanayi şirketleri, limanlar ve şantiyeler
                                    için ruhsat gerektirmeyen, hızlı kurulumlu
                                    dev çelik konstrüksiyonlar.
                                </p>
                                <a href="/depo-cadiri" class="btn-product"
                                    >Detayları İncele <span>→</span></a
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Afet Çadırı -->
                    <div class="col mb-4">
                        <div class="product-card bg-white">
                            <div class="card-img-wrapper">
                                <img
                                    src="/style/brand/img/afet-cadiri.webp"
                                    class="img-fluid"
                                    alt="Afet ve Deprem Çadırı"
                                    loading="lazy"
                                />
                            </div>
                            <div class="product-card-body">
                                <h3 class="h5 font-weight-bold">
                                    Afet & Taziye Çadırı
                                </h3>
                                <p class="text-muted small">
                                    Kurumlar ve belediyeler için acil barınma
                                    amaçlı yalıtımlı sığınak / toplanma alanı
                                    çelik iskeletli çadırlar.
                                </p>
                                <div
                                    class="d-flex flex-column mt-auto pt-2"
                                    style="gap: 8px;"
                                >
                                    <a
                                        href="/afet-deprem-cadiri"
                                        class="btn-product m-0"
                                        >Afet Çadırı Detayları <span>→</span></a
                                    >
                                    <a
                                        href="/taziye-cadiri"
                                        class="btn-product m-0"
                                        >Taziye Çadırı Detayları <span>→</span
                                        ></a
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="space50"></div>

        <!-- Kategori 3: Kamyon ve Branda Kumaşları -->
        <div class="category-section mt-5">
            <div class="text-center mb-5">
                <h2 class="display-6 font-weight-bold mb-3">
                    Ticari Araçlar ve Kumaş Satışı
                </h2>
                <hr
                    class="w-10 mx-auto mb-4 border-2 border-primary"
                    style="width: 60px; border-top: 3px solid #4c86e5; border-radius: 5px;"
                />
            </div>

            <div
                class="row row-cols-1 row-cols-md-2 g-4 justify-content-center"
            >
                <!-- Tır Brandası -->
                <div class="col mb-4">
                    <div
                        class="product-card d-flex flex-row overflow-hidden align-items-stretch"
                        style="min-height: 200px;"
                    >
                        <div class="card-img-wrapper w-50 h-100">
                            <img
                                src="/style/brand/img/kamyon-brandasi.webp"
                                class="img-fluid h-100 w-100"
                                style="object-fit: cover;"
                                alt="Tır ve Dorse Brandası"
                                loading="lazy"
                            />
                        </div>
                        <div
                            class="product-card-body w-50 d-flex flex-column justify-content-center"
                        >
                            <h3 class="h5 font-weight-bold">
                                Ticari Tır & Kamyonet Brandası
                            </h3>
                            <p class="text-muted small">
                                Tüm lojistik çekici grupları için uluslararası
                                gümrük (TIR) standartlarında 900gr PVC kayar
                                perde ve kargo kapatmaları.
                            </p>
                            <a href="/tir-brandasi" class="btn-product mt-auto"
                                >Aracınıza Uygun Model Seçin <span>→</span></a
                            >
                        </div>
                    </div>
                </div>

                <!-- Kumaşlar ve Diğer -->
                <div class="col mb-4">
                    <div
                        class="product-card d-flex flex-row overflow-hidden align-items-stretch"
                        style="min-height: 200px;"
                    >
                        <div
                            class="card-img-wrapper w-50 h-100 bg-dark position-relative"
                        >
                            <img
                                src="/style/brand/img/akrilik-kumas.webp"
                                class="img-fluid h-100 w-100"
                                style="object-fit: cover; opacity: 0.8;"
                                alt="Akrilik ve PVC Kumaş"
                                loading="lazy"
                            />
                            <div
                                class="position-absolute text-white font-weight-bold p-3"
                                style="bottom:0; left:0; text-shadow: 1px 1px 3px rgba(0,0,0,0.8);"
                            >
                                %100 Akrilik Dokuma
                            </div>
                        </div>
                        <div
                            class="product-card-body w-50 d-flex flex-column justify-content-center"
                        >
                            <h3 class="h5 font-weight-bold">
                                Toptan Kumaş & Rulo Satışı
                            </h3>
                            <p class="text-muted small">
                                Avrupa ithal solmaz Akrilik tente kumaşları
                                (Dickson, Sauleda), Pilsa ve PVC Polyester
                                (Blackout) membran rulo (top) satışlarımız
                                mevcuttur.
                            </p>
                            <a href="/akrilik" class="btn-product mt-auto"
                                >Kumaş Kataloğu <span>→</span></a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Call to Action -->
        <div
            class="cta-banner mt-5 mt-md-7 position-relative overflow-hidden shadow-lg"
            style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);"
        >
            <div
                class="position-absolute w-100 h-100"
                style="top:0; left:0; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);"
            >
            </div>
            <div
                class="position-relative text-white p-5 text-center text-md-left d-md-flex align-items-center justify-content-between"
            >
                <div class="mb-4 mb-md-0">
                    <h4 class="text-white font-weight-bold mb-2">
                        Eski Tentenizi Yenileyin!
                    </h4>
                    <p
                        class="mb-0"
                        style="color: rgba(255,255,255,0.7); font-size: 1.1rem;"
                    >
                        Bozulan mafsal kolları, yırtılan kumaşlar veya arızalı
                        motorlar için
                        <a
                            href="/tente-tamiri-bakimi"
                            class="text-primary text-decoration-underline font-weight-bold"
                            >Tente Tamiri & Servis</a
                        > hizmeti alabilirsiniz.
                    </p>
                </div>
                <div>
                    <a
                        href="/iletisim"
                        class="btn btn-primary btn-lg font-weight-bold"
                        style="border-radius: 30px; box-shadow: 0 5px 15px rgba(76, 134, 229, 0.4);"
                    >
                        Fiyat Teklifi Al
                    </a>
                </div>
            </div>
        </div>
    </article>
</PageLayout>

<style>
    /* Premium Product Variables */
    :root {
        --card-radius: 8px;
        --card-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        --card-shadow-hover: 0 10px 25px rgba(76, 134, 229, 0.15);
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    /* Product Cards */
    .product-card {
        background: #fff;
        border-radius: var(--card-radius);
        box-shadow: var(--card-shadow);
        transition: var(--transition);
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--card-shadow-hover);
        border-color: rgba(76, 134, 229, 0.2);
    }

    .card-img-wrapper {
        position: relative;
        width: 100%;
        height: 220px;
        overflow: hidden;
    }

    .card-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .product-card:hover .card-img-wrapper img {
        transform: scale(1.05);
    }

    .product-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 10;
        padding: 5px 12px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        border-radius: 4px;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.15);
        color: white;
    }

    .product-card-body {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .btn-product {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        color: #4c86e5;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
        transition: var(--transition);
    }

    .btn-product span {
        margin-left: 5px;
        transition: transform 0.3s ease;
    }

    .btn-product:hover {
        color: #2b5cb8;
        text-decoration: none;
    }

    .btn-product:hover span {
        transform: translateX(5px);
    }

    .gap-2 {
        gap: 0.5rem;
    }
    .max-w-700 {
        max-width: 700px;
    }
</style>
