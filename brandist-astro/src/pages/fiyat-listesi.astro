                                <tr>
                                    <td><strong>Mafsallı Tente</strong></td>
                                    <td>Standart akrilik kumaşlı, manuel açılır balkon/dükkan tentesi.</td>
                                    <td>İletişime Geçin</td>
                                </tr>
                                <tr>
                                    <td><strong>Pergola Motorlu Tente (m2)</strong></td>
