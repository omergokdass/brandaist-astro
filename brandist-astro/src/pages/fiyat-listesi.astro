---
import Layout from "../layouts/Layout.astro";
const currentYear = new Date().getFullYear();

const faqData = [
    {
      question: "Tente ve branda fiyatlarına montaj dahil mi?",
      answer: "Evet, Amir Branda olarak İstanbul içi sunduğumuz tüm tente, kış bahçesi ve depo çadırı fiyat tekliflerimize nakliye ve uzman ekibimiz tarafından yapılan anahtar teslim montaj işlemi dahildir."
    },
    {
      question: "Ücretsiz keşif hizmetiniz var mı?",
      answer: "Kesinlikle! Projenizin büyüklüğü ne olursa olsun, mekanınızı yerinde incelemek, ölçü almak ve size en uygun branda sistemini önermek için ücretsiz keşif hizmeti sunuyoruz."
    },
    {
      question: "M2 (Metrekare) fiyatı kumaş türüne göre ne kadar fark eder?",
      answer: "Kumaş seçimi fiyatı doğrudan etkiler. Ekonomik bir branda m2 başına daha uygunken, 10 yıl solmazlık garantili Avrupa akrilik kumaşlar m2 başına daha yüksek bir fiyata sahiptir."
    },
    {
      question: "Sipariş verildikten sonra teslimat süresi nedir?",
      answer: "Standart ürünlerde teslimat süremiz 3-5 iş günüdür. Kış bahçesi veya pergola gibi büyük projelerin imalatı ise 1-2 hafta arasında tamamlanmaktadır."
    }
];
---

<Layout
    title="Amir Branda | En Ucuz Tente ve Branda Fiyat Listesi 2026"
    description="Amir Branda 2026 güncel kampanya ve fiyat listesi. İstanbul'da en uygun şeffaf branda m2 fiyatları, indirimli mafsallı tente ve ucuz çadır fiyat hesaplama."
    ogTitle="Amir Branda | En Ucuz Tente ve Branda Fiyat Listesi 2026"
    faqData={faqData}
>
    <!-- Header Hero Section -->
    <div
        class="relative bg-gray-900 overflow-hidden isolate px-6 py-24 sm:py-32 lg:px-8"
    >
        <div class="mx-auto max-w-4xl text-center">
            <h1
                class="text-4xl font-bold tracking-tight text-white sm:text-6xl"
            >
                Güncel Fiyat Listesi
            </h1>
            <p class="mt-6 text-xl leading-8 text-gray-300 font-medium">
                İhtiyacınıza uygun branda ve tente sistemleri için en rekabetçi
                fiyatlar ve özel çözümler.
            </p>
